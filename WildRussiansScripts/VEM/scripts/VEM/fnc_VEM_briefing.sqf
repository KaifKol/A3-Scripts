if (!hasInterface) exitWith {};
waitUntil { !isNull player };

player createDiaryRecord ["Diary", [
    "Внешний вид техники",
    "Позволяет изменять навесное оборудование техники прямо в игре: маскировочные сети, антенны, лестницы, канистры и другие компоненты.<br/><br/>" +

    "<font size='16' color='#00BFFF'>Где доступно</font><br/>" +
    "Меню доступно только в зоне обслуживания на базе (радиус <font color='#FFFF00'>50 метров</font> от точки техобслуживания).<br/><br/>" +

    "<font size='16' color='#00BFFF'>Как открыть</font><br/>" +
    "Подойди к <font color='#FFFF00'>пустой технике</font> и наведи на неё прицел — в контекстном меню появится пункт<br/>" +
    "<font color='#FFFF00'>«Внешний вид техники»</font>.<br/>" +
    "Также можно открыть меню <font color='#FFFF00'>находясь за рулём</font> своей машины.<br/><br/>" +

    "<font size='16' color='#00BFFF'>Как пользоваться</font><br/>" +
    "1. Открой меню — в списке отображаются все доступные компоненты.<br/>" +
    "2. <font color='#FFFF00'>Выбери компонент</font> из списка (одиночный клик — только выделение).<br/>" +
    "3. Нажми кнопку <font color='#00FF88'>«Применить / Отключить»</font> — компонент включится или выключится.<br/>" +
    "4. <font color='#00FF88'>Зелёный цвет</font> названия означает что компонент <font color='#00FF88'>активен</font> прямо сейчас.<br/><br/>" +

    "<font size='16' color='#00BFFF'>Сброс</font><br/>" +
    "Кнопка <font color='#FF6666'>«Сброс»</font> возвращает технику к стандартному заводскому виду.<br/><br/>" +

    "<font color='#FF4444'>Изменения видны всем игрокам. Техника должна быть без экипажа или под вашим управлением.</font>"
